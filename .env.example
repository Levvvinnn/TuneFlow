# ── Qwen Cloud ────────────────────────────────────────────────
QWEN_API_KEY=sk-your-qwen-cloud-api-key-here
# Text/reasoning model (Config Agent, Optimizer, baseline god-agent)
QWEN_TEXT_MODEL=qwen-plus
# Stronger reasoning model for Optimizer tradeoff decisions
QWEN_OPTIMIZER_MODEL=qwen-max
# Vision-capable model for Judge chart analysis
QWEN_VISION_MODEL=qwen-vl-plus
# Qwen Cloud API base URL
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Service under test ─────────────────────────────────────────
SERVICE_DB_URL=postgresql://service_user:service_pass@localhost:5432/service_db
SERVICE_HOST=http://localhost:8000
# Initial config (overridden at runtime by agents)
INITIAL_POOL_SIZE=5
INITIAL_QUERY_TIMEOUT_MS=5000
INITIAL_CACHE_TTL_SECONDS=60
INITIAL_BATCH_SIZE=100
INITIAL_RETRY_INTERVAL_MS=100

# ── Persistence DB (separate from service DB) ──────────────────
PERSISTENCE_DB_URL=postgresql://persist_user:persist_pass@localhost:5433/persistence_db

# ── Orchestrator ───────────────────────────────────────────────
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8080

# ── Load test ─────────────────────────────────────────────────
LOAD_TEST_VUS=100
LOAD_TEST_DURATION_SECONDS=30
LOAD_TEST_REPEATS=2

# ── Agent loop ─────────────────────────────────────────────────
MAX_ITERATIONS=15
PLATEAU_N=3
# Target p95 latency in ms — loop stops if achieved
TARGET_P95_MS=200

# ── Alibaba Cloud (for deployment scripts) ─────────────────────
ALIBABA_ACCESS_KEY_ID=your-access-key-id
ALIBABA_ACCESS_KEY_SECRET=your-access-key-secret
ALIBABA_REGION_ID=ap-southeast-1
ALIBABA_ECS_INSTANCE_ID=i-your-ecs-instance-id
ALIBABA_RDS_INSTANCE_ID=pgm-your-rds-instance-id
