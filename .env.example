# ── Fireworks AI — see agents/fireworks_client.py ──────────────────────
FIREWORKS_API_KEY=fw_your-fireworks-api-key-here
# Text/reasoning model (Config Agent, Optimizer, baseline god-agent)
# Confirmed serverless as of Jul 2026 — check https://fireworks.ai/models for updates
FIREWORKS_TEXT_MODEL=accounts/fireworks/models/deepseek-v4-flash
# Stronger reasoning model for Optimizer tradeoff decisions
FIREWORKS_OPTIMIZER_MODEL=accounts/fireworks/models/deepseek-v4-flash
# Vision-capable model for Judge chart analysis
# NOTE: As of Jul 2026 no serverless vision model is available on Fireworks;
# vision calls fail gracefully — judge_agent.diagnose_vision has a try/except fallback.
FIREWORKS_VISION_MODEL=accounts/fireworks/models/deepseek-v4-flash
# Fireworks AI API base URL
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ── Service under test ─────────────────────────────────────────
SERVICE_DB_URL=postgresql://service_user:service_pass@localhost:5432/service_db
SERVICE_HOST=http://localhost:8000
# Initial config (overridden at runtime by agents)
INITIAL_POOL_SIZE=5
INITIAL_QUERY_TIMEOUT_MS=5000
INITIAL_CACHE_TTL_SECONDS=60
INITIAL_BATCH_SIZE=100
INITIAL_RETRY_INTERVAL_MS=100

# ── Persistence DB (separate from service DB) ──────────────────
PERSISTENCE_DB_URL=postgresql://persist_user:persist_pass@localhost:5433/persistence_db

# ── Orchestrator ───────────────────────────────────────────────
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8080

# ── Load test ─────────────────────────────────────────────────
LOAD_TEST_VUS=100
LOAD_TEST_DURATION_SECONDS=30
LOAD_TEST_REPEATS=2

# ── Agent loop ─────────────────────────────────────────────────
MAX_ITERATIONS=15
PLATEAU_N=3
# Target p95 latency in ms — loop stops if achieved
TARGET_P95_MS=200

